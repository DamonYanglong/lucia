{
  "name": "@lucia/core",
  "version": "0.1.0",
  "description": "Lucia core package",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/app.ts",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && pnpm test:integration"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@lucia/plugin-store-trace-clickhouse": "workspace:*",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.0.0",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
